# ===== TripMind AI - Environment Variables =====
# Copy this file to .env and fill in your keys

GEMINI_API_KEY=your_gemini_api_key_here
WEATHER_API_KEY=your_openweather_api_key_here

# Supabase PostgreSQL (recommended)
# DB_URL=jdbc:postgresql://db.<project-ref>.supabase.co:5432/postgres?sslmode=require
# DB_DRIVER=org.postgresql.Driver
# DB_USER=postgres.<project-ref>
# DB_PASSWORD=your_database_password
# JPA_DIALECT=org.hibernate.dialect.PostgreSQLDialect
# JPA_DDL_AUTO=update

# CORS for deployed frontend domains (comma-separated)
# APP_CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com

# Admin credentials (MUST change in production)
# ADMIN_USER=admin
# ADMIN_PASS=strong-long-random-password

# Email configuration (for Admin Notification)
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASS=your_app_password
